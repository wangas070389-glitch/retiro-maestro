generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // Hashed password for Credentials provider
  accounts      Account[]
  sessions      Session[]
  simulations   Simulation[]
  tier          String    @default("FREE") // FREE, STRATEGY, DOSSIER, STARTER, GROWTH, PRO
  role          String    @default("USER") // USER, ADVISOR, ADMIN
  subscriptionStatus String? // "ACTIVE", "PAST_DUE", "CANCELED"
  isApproved    Boolean   @default(false)
  isBlocked     Boolean   @default(false)
  trialSimulationsUsed Int @default(0)

  // B2B2C Advisor CRM Mapping (ADR-034)
  advisorId     String?
  advisor       User?     @relation("AdvisorClients", fields: [advisorId], references: [id])
  clients       User[]    @relation("AdvisorClients")
  
  // Professional Advisor Clients (B2B Leads)
  managedClients Client[]
  
  // Marca Blanca (B2B Advisor Strategy)
  agencyName    String?
  agencyPhone   String?
  agencyLogoUrl String?

  // Decentralized Ingestion (Epic 15)
  magicLinkToken   String? @unique
  magicLinkExpires DateTime?

  // B2B2C Geo-Spatial Auction Routing (Epics 16-18)
  operationState   String?
  remoteReady      Boolean @default(false)
  residencyState   String?
  leadStatus       String  @default("NONE") // NONE, PENDING_INTERNAL, PENDING_LOCAL, PENDING_NATIONAL, CLAIMED
  slaExpiresAt     DateTime?
  
  claimedById      String?
  claimedBy        User?   @relation("ClaimedLeads", fields: [claimedById], references: [id])
  claimedLeads     User[]  @relation("ClaimedLeads")
  
  wageHistories    WageHistory[]

  // Actuarial Metadata (Sovereign CRM Sync)
  nss             String?
  birthDate       DateTime?
  isWorking       Boolean   @default(false)
  age             Int?
  currentWeeks    Int?
  avgSalary       Float?
  lastBajaDate    DateTime?
  activeStrategy  String?
  m40PaymentsState String?
  
  // CRM Closing Machine (v3.0.0-terminal)
  currentStage    String    @default("PROSPECT") // PROSPECT, ANALYZING, PROPOSAL_SENT, CLOSED_WIN, CLOSED_LOSS
  nextAction      String?   // FOLLOW_UP, CALL, MEETING
  nextActionAt    DateTime?
  selectedStrategyId String?
  closingNarrative   String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}


model Client {
  id            String    @id @default(uuid())
  advisorId     String
  advisor       User      @relation(fields: [advisorId], references: [id])
  name          String
  email         String?
  phone         String?
  notes         String?
  status        String    @default("PROSPECT") // PROSPECT, SIMULATION_DONE, CONTRACTED
  
  simulations   Simulation[]
  
  // Actuarial Metadata (Sovereign CRM Sync)
  nss           String?
  birthDate     DateTime?
  isWorking     Boolean   @default(false)
  age           Int?
  currentWeeks  Int?
  avgSalary     Float?
  lastBajaDate  DateTime?
  activeStrategy  String?
  m40PaymentsState String?

  // CRM Closing Machine (v3.0.0-terminal)
  currentStage    String    @default("PROSPECT") // PROSPECT, ANALYZING, PROPOSAL_SENT, CLOSED_WIN, CLOSED_LOSS
  nextAction      String?   // FOLLOW_UP, CALL, MEETING
  nextActionAt    DateTime?
  selectedStrategyId String?
  closingNarrative   String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Simulation {
  id             String   @id @default(uuid())
  userId         String?
  user           User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId       String?
  client         Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  name           String   // e.g. "My Escalera Plan 1"
  input          String   // JSON string of PensionInput
  result         String?  // JSON string of PensionResult
  integrity_hash String?  // SHA-256 (ADR-004)
  is_forensic    Boolean  @default(false)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  strategies Strategy[]
}


model Strategy {
  id           String     @id @default(uuid())
  simulationId String
  simulation   Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  type         String     // "INERCIAL", "RAMPA", "TOPADO"
  investment   Float      // Total M40 Cost
  netPension   Float      // Monthly Net
  roiMonths    Float      // Payback Period
  createdAt    DateTime   @default(now())
}

model EconomicAnchor {
  id            String   @id @default(uuid())
  year          Int
  uma           Float
  inpc          Float
  smdf          Float
  source        String   // e.g. "DOF/INEGI"
  is_verified   Boolean  @default(false)
  signature     String?  // Cryptographic seal (ADR-004)
  
  active_from   DateTime @default(now())
  createdAt     DateTime @default(now())

  @@unique([year, source])
}

model WageHistory {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  employer        String
  movementDate    DateTime
  type            String   // REINGRESO, BAJA, MODIFICACION
  dailyWage       Float
  createdAt       DateTime @default(now())
}

